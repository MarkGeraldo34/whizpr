# ---------------------------------------------------------------------------
# Whizpr environment variables
# Copy this file to .env.local for local dev, and set the same keys in
# Vercel Project Settings > Environment Variables for Preview/Production.
# ---------------------------------------------------------------------------

# --- Chain / RPC ---
# Public RPC used by the client (Wagmi) to read chain state.
NEXT_PUBLIC_CHAIN_RPC_URL=https://your-rpc-endpoint
# Server-side RPC (can be the same URL, or a private/authenticated one with
# higher rate limits) used by viem on the server to verify on-chain deposits.
SERVER_RPC_URL=https://your-rpc-endpoint
# Chain ID the app operates on.
NEXT_PUBLIC_CHAIN_ID=196

# --- USDT token / deposit verification ---
# ERC-20 contract address for USDT on the target chain.
NEXT_PUBLIC_USDT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# Treasury/deposit address users send USDT to when prepaying.
NEXT_PUBLIC_DEPOSIT_ADDRESS=0x0000000000000000000000000000000000000000
# Minimum block confirmations required before a deposit is credited to the ledger.
DEPOSIT_MIN_CONFIRMATIONS=3

# --- SIWE-lite session ---
# Random 32+ byte secret used to sign session cookies (generate with:
# `openssl rand -hex 32`). Never reuse across environments.
SESSION_SECRET=replace-with-a-long-random-string
# Domain shown in the SIWE message (must match the deployed domain).
NEXT_PUBLIC_SIWE_DOMAIN=whizpr.vercel.app

# --- OnchainOS Wallet API (HMAC-signed) ---
OKX_ONCHAINOS_API_BASE_URL=https://api.onchainos.okx.com
OKX_ONCHAINOS_API_KEY=your-api-key
OKX_ONCHAINOS_API_SECRET=your-api-secret
# Some OnchainOS setups additionally require a passphrase alongside key/secret.
OKX_ONCHAINOS_API_PASSPHRASE=your-api-passphrase

# --- Database ---
# Postgres connection string used by every lib/*-store.ts module (reports,
# ledger, bans, profiles, responders). Get one by adding a database in
# Vercel's Storage tab (Create Database > Neon) or `vercel install neon` —
# that provisions this automatically. POSTGRES_URL is accepted as a
# fallback if you're using Vercel's native Postgres product instead of Neon.
# Tables are created automatically on first use — no separate migration step.
DATABASE_URL=

# --- Emergency media storage ---
# Where uploaded emergency media (photo/video) is stored. Recommended:
# Vercel Blob. Set the token Vercel provisions when you add the Blob store.
BLOB_READ_WRITE_TOKEN=

# --- Content moderation ---
# Comma-separated wallet addresses allowed to review reports and apply
# moderation penalties (Whizcredit removal / bans) via /api/moderation/*.
# Whizpr has no separate admin login — an admin is just a wallet in this
# list that has signed in normally via SIWE.
ADMIN_ADDRESSES=

# --- AI triage (content moderation) ---
# Anthropic API key used to have Claude look at each submitted photo and
# judge whether it's genuine hazard footage before responders are emailed.
# Without this set, report submission still succeeds — triage is just
# skipped (logged server-side) and responders are notified as before.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# --- Responder notification email ---
# Resend API key used to email first responders when a new report comes in
# for their country. Get one at https://resend.com. Without this set,
# report submission still succeeds — the notification email is just skipped
# (logged server-side).
RESEND_API_KEY=
# Verified sender address/name for responder alert emails. Must be on a
# domain you own and have verified in the Resend dashboard (Domains > Add
# Domain) — you can't verify a *.vercel.app subdomain since you don't
# control its DNS. Leave unset to use Resend's shared test sender
# (onboarding@resend.dev), which only delivers to your own Resend account
# email — fine for local testing, not for real responders.
RESEND_FROM_EMAIL=Whizpr Alerts <alerts@yourdomain.com>
